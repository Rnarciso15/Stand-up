@page "/veiculos"
@rendermode InteractiveServer
@inject VehicleApiClient Api
@inject FavoritesService Favorites
@inject CompareService Compare
@inject IJSRuntime JS

<PageTitle>Catálogo de Viaturas — Stand Up</PageTitle>
<HeadContent>
    <meta name="description" content="Catálogo de viaturas premium — automóveis e motociclos de alta qualidade. Stand Up, Lisboa." />
</HeadContent>

<div style="padding-top:68px">
  <div class="su-section" style="padding-bottom:0">
    <div class="su-section-header">
      <div>
        <div class="su-section-eyebrow">Disponível em Stock</div>
        <h1 class="su-section-title">Catálogo</h1>
      </div>
    </div>

    @if (!_loading)
    {
      <div class="su-filter-bar">
        <div class="su-filter-group">
          <label class="su-filter-label">Marca</label>
          <BrandCombobox @bind-SelectedBrand="_filterBrand" Brands="_brands" />
        </div>

        <div class="su-filter-group">
          <label class="su-filter-label">Modelo / texto livre</label>
          <input class="su-filter-input" @bind="_filterModel" @bind:event="oninput" placeholder="Ex: M3, GR Supra..." />
        </div>

        <div class="su-filter-group">
          <label class="su-filter-label">Combustível</label>
          <select class="su-filter-select" @bind="_filterFuel">
            <option value="">Todos</option>
            @foreach (var f in _fuels) { <option value="@f">@f</option> }
          </select>
        </div>

        <div class="su-filter-group">
          <label class="su-filter-label">Tipo</label>
          <select class="su-filter-select" @bind="_filterType">
            <option value="">Todos</option>
            <option value="car">Automóvel</option>
            <option value="moto">Moto</option>
          </select>
        </div>

        <div class="su-filter-group su-filter-range-group">
          <label class="su-filter-label">Preço &nbsp;<span class="su-filter-range-val">€@_priceMin.ToString("N0") – €@_priceMax.ToString("N0")</span></label>
          <div class="su-filter-range-row">
            <input type="range" class="su-calc-range" min="0" max="@_maxPriceData" step="1000" @bind="_priceMin" @bind:event="oninput" />
            <input type="range" class="su-calc-range" min="0" max="@_maxPriceData" step="1000" @bind="_priceMax" @bind:event="oninput" />
          </div>
        </div>

        <div class="su-filter-group su-filter-range-group">
          <label class="su-filter-label">Quilómetros &nbsp;<span class="su-filter-range-val">@_kmMin.ToString("N0") – @_kmMax.ToString("N0") km</span></label>
          <div class="su-filter-range-row">
            <input type="range" class="su-calc-range" min="0" max="@_maxKmData" step="5000" @bind="_kmMin" @bind:event="oninput" />
            <input type="range" class="su-calc-range" min="0" max="@_maxKmData" step="5000" @bind="_kmMax" @bind:event="oninput" />
          </div>
        </div>

        @if (HasActiveFilters)
        {
          <button class="su-filter-btn reset" @onclick="ClearFilters">✕ Limpar</button>
        }
      </div>
    }
  </div>

  <div class="su-section" style="padding-top:1.5rem">
    @if (_loading)
    {
      <div class="su-loading"><div class="su-spinner"></div><div class="su-loading-text">A carregar catálogo</div></div>
    }
    else if (_apiOffline)
    {
      <div class="su-offline">⚠ Servidor indisponível. Verifique que a API está a correr e recarregue a página.</div>
    }
    else
    {
      var list = Filtered.ToList();
      <p class="su-results-count"><strong>@list.Count</strong> viatura(s) encontrada(s)</p>

      @if (list.Count == 0)
      {
        <div class="su-empty">
          <div class="su-empty-icon">🔍</div>
          <div class="su-empty-text">Nenhuma viatura corresponde aos filtros.</div>
        </div>
      }
      else
      {
        <div class="su-grid">
          @foreach (var v in list)
          {
            var isFav     = _favorites.Contains(v.LicensePlate);
            var inCompare = Compare.Has(v.LicensePlate);
            var isNew     = v.AddedAt.HasValue && (DateTime.UtcNow - v.AddedAt.Value).TotalDays < 30;

            <div class="su-card-wrap">
              <a href="/veiculos/@Uri.EscapeDataString(v.LicensePlate)" class="su-card">
                <div class="su-card-img">
                  @if (_images.TryGetValue(v.LicensePlate, out var img) && img is not null)
                  {
                    <img src="data:image/jpeg;base64,@img" alt="@v.Brand @v.Model" loading="lazy" />
                  }
                  else
                  {
                    <div class="su-card-placeholder">
                      <span class="su-card-placeholder-icon">@(v.IsMotorcycle ? "🏍" : "🚗")</span>
                    </div>
                  }
                  @if (isNew) { <div class="su-card-badge new">Novo</div> }
                </div>
                <div class="su-card-body">
                  <div class="su-card-brand">@v.Brand</div>
                  <div class="su-card-name">@v.Model</div>
                  <div class="su-card-plate">@v.LicensePlate</div>
                  <div class="su-card-meta">
                    @if (!string.IsNullOrWhiteSpace(v.Fuel))
                    {
                      <span class="su-tag fuel-@v.Fuel!.ToLowerInvariant()">@v.Fuel</span>
                    }
                    @if (v.IsMotorcycle) { <span class="su-tag mota">Moto</span> }
                  </div>
                  <div class="su-card-footer">
                    <div>
                      <div class="su-card-price">€@v.Price.ToString("N0", new System.Globalization.CultureInfo("pt-PT"))</div>
                      <div class="su-card-km">@v.Kilometers.ToString("N0") km</div>
                    </div>
                    <div class="su-card-arrow">→</div>
                  </div>
                </div>
              </a>

              <div class="su-card-actions">
                <button class="su-card-action-btn @(isFav ? "active" : "")" @onclick="() => ToggleFavorite(v.LicensePlate)" title="@(isFav ? "Remover favorito" : "Adicionar favorito")">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="@(isFav ? "currentColor" : "none")" stroke="currentColor" stroke-width="2">
                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                  </svg>
                </button>
                <button class="su-card-action-btn @(inCompare ? "active" : "") @(Compare.Count >= 3 && !inCompare ? "disabled" : "")"
                        @onclick="() => Compare.Toggle(v.LicensePlate)"
                        title="@(inCompare ? "Remover do comparador" : "Adicionar ao comparador")"
                        disabled="@(Compare.Count >= 3 && !inCompare)">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="3" width="7" height="18" rx="1"/><rect x="14" y="3" width="7" height="18" rx="1"/>
                  </svg>
                </button>
              </div>
            </div>
          }
        </div>
      }
    }
  </div>

  @if (Compare.Count > 0)
  {
    <div class="su-compare-bar">
      <span>@Compare.Count viatura(s) selecionada(s)</span>
      <a href="/comparar" class="su-btn-primary" style="padding:.4rem 1.2rem;font-size:.85rem">Comparar</a>
      <button class="su-compare-bar-clear" @onclick="Compare.Clear">Limpar</button>
    </div>
  }
</div>

@code {
    [SupplyParameterFromQuery(Name = "q")]    private string? Q    { get; set; }
    [SupplyParameterFromQuery(Name = "tipo")] private string? Tipo { get; set; }

    private List<VehicleDto> _all    = [];
    private Dictionary<string, string?> _images   = [];
    private HashSet<string> _favorites = [];
    private bool _loading    = true;
    private bool _apiOffline;
    private List<string> _brands = [];
    private List<string> _fuels  = [];

    private string _filterBrand = "";
    private string _filterModel = "";
    private string _filterFuel  = "";
    private string _filterType  = "";
    private int    _priceMin;
    private int    _priceMax    = int.MaxValue;
    private int    _kmMin;
    private int    _kmMax       = int.MaxValue;
    private int    _maxPriceData;
    private int    _maxKmData;

    private bool HasActiveFilters =>
        !string.IsNullOrWhiteSpace(_filterBrand) || !string.IsNullOrWhiteSpace(_filterModel) ||
        !string.IsNullOrWhiteSpace(_filterFuel)  || !string.IsNullOrWhiteSpace(_filterType)  ||
        _priceMin > 0 || _priceMax < _maxPriceData || _kmMin > 0 || _kmMax < _maxKmData;

    private IEnumerable<VehicleDto> Filtered => _all.Where(v =>
        (string.IsNullOrWhiteSpace(_filterBrand) || v.Brand.Equals(_filterBrand, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrWhiteSpace(_filterModel) || v.Model.Contains(_filterModel, StringComparison.OrdinalIgnoreCase) || v.Brand.Contains(_filterModel, StringComparison.OrdinalIgnoreCase) || v.LicensePlate.Contains(_filterModel, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrWhiteSpace(_filterFuel)  || v.Fuel == _filterFuel) &&
        (_filterType == "" || (_filterType == "moto" && v.IsMotorcycle) || (_filterType == "car" && !v.IsMotorcycle)) &&
        v.Price >= _priceMin && v.Price <= _priceMax &&
        v.Kilometers >= _kmMin && v.Kilometers <= _kmMax);

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrWhiteSpace(Q))    _filterModel = Q;
        if (!string.IsNullOrWhiteSpace(Tipo)) _filterType  = Tipo == "mota" ? "moto" : Tipo;
        try
        {
            _all = await Api.GetAvailableAsync();
            _apiOffline = false;
            _brands = _all.Select(v => v.Brand).Distinct().OrderBy(b => b).ToList();
            _fuels  = _all.Where(v => !string.IsNullOrWhiteSpace(v.Fuel)).Select(v => v.Fuel!).Distinct().OrderBy(f => f).ToList();
            _maxPriceData = _all.Count > 0 ? _all.Max(v => v.Price)      : 500_000;
            _maxKmData    = _all.Count > 0 ? _all.Max(v => v.Kilometers) : 300_000;
            _priceMax = _maxPriceData;
            _kmMax    = _maxKmData;
            foreach (var v in _all)
                _images[v.LicensePlate] = await Api.GetVehicleImageBase64Async(v.LicensePlate);
        }
        catch { _apiOffline = true; }
        finally { _loading = false; }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var plates = await Favorites.GetPlatesAsync();
        _favorites = [..plates];
        StateHasChanged();
    }

    private async Task ToggleFavorite(string plate)
    {
        await Favorites.ToggleAsync(plate);
        if (_favorites.Contains(plate)) _favorites.Remove(plate);
        else _favorites.Add(plate);
    }

    private void ClearFilters()
    {
        _filterBrand = ""; _filterModel = ""; _filterFuel = ""; _filterType = "";
        _priceMin = 0; _priceMax = _maxPriceData; _kmMin = 0; _kmMax = _maxKmData;
    }
}
